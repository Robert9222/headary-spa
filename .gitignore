# ====== IDE / Editors ======
.idea/
.vscode/
*.iml
*.suo
*.user
*.swp
*.swo

# ====== OS junk ======
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ====== Środowisko / sekrety ======
# (Te pliki NIGDY nie powinny trafić na GitHub)
.env
.env.local
.env.*.local
*.pem
*.key

# ====== Logi ======
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ====== Lokalna baza SQLite ======
backend/database/database.sqlite
backend/database/*.sqlite-journal

# ====== Storage ======
# Śledzimy CAŁY katalog backend/storage (włącznie z runtime: framework, logs, app/private).
# Symlink backend/public/storage -> backend/storage/app/public nadal ignorujemy.
backend/public/storage
!backend/storage/
!backend/storage/**
!backend/storage/**/*.log
!backend/storage/**/*.key

# ====== Frontend build / cache ======
frontend/dist/
frontend/.angular/
frontend/coverage/

# ====== Backend build / cache ======
backend/vendor/
backend/node_modules/
backend/public/build/
backend/public/hot
backend/.phpunit.result.cache
backend/.phpunit.cache/

# ====== Node ======
node_modules/

# ====== Testy / coverage ======
coverage/
.nyc_output/

# ====== Backupy / dumpy bazy / archiwa (NIE wrzucamy na GitHub) ======
backend.zip
*.zip
exports/
*.sql
*.sqlite
*.sqlite-journal
backend/_backfill.php
backend/dump-sqlite.php
backend/dump-postgres.php


